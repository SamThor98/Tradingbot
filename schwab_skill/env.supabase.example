# Paste-friendly env template for Supabase-hosted Postgres + JWT.
# Copy to `.env` (gitignored) or paste KEY=value lines into Render → Environment.
#
# Fill the PASTE_* placeholders from Supabase Dashboard → Project Settings → API
# (anon key, JWT secret). Database password: Settings → Database (not the JWT secret).
# Generate CREDENTIAL_ENCRYPTION_KEY:
#   python3 -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
#
# --- Web + worker (same values on both Render services where applicable) ---

DATABASE_URL=postgresql+psycopg2://postgres:PASTE_DATABASE_PASSWORD@db.blfzgeamkovnwlxqbruo.supabase.co:5432/postgres

# If direct connection fails (IPv4-only host), use Session pooler from Supabase Connect instead:
# DATABASE_URL=postgresql+psycopg2://postgres.blfzgeamkovnwlxqbruo:PASTE_DATABASE_PASSWORD@aws-0-PASTE_REGION.pooler.supabase.com:5432/postgres

SUPABASE_URL=https://blfzgeamkovnwlxqbruo.supabase.co

# Project Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=PASTE_SUPABASE_ANON_KEY

# Project Settings → API → JWT Settings → JWT Secret (legacy symmetric secret for HS256)
SUPABASE_JWT_SECRET=PASTE_SUPABASE_JWT_SECRET

# Optional: previous secret during rotation
# SUPABASE_JWT_SECRET_LEGACY=

# Optional: stricter match to browser access tokens (aud / iss)
SUPABASE_JWT_STRICT_CLAIMS=1

# Required for encrypted Schwab credentials (32 bytes, url-safe base64 — see command above)
CREDENTIAL_ENCRYPTION_KEY=PASTE_URLSAFE_BASE64_32_BYTES

# Your deployed API origin(s), comma-separated (CORS)
WEB_ALLOWED_ORIGINS=https://YOUR-API.onrender.com

# --- Schwab (fill when using OAuth) ---
# SCHWAB_MARKET_APP_KEY=
# SCHWAB_MARKET_APP_SECRET=
# SCHWAB_ACCOUNT_APP_KEY=
# SCHWAB_ACCOUNT_APP_SECRET=
# SCHWAB_CALLBACK_URL=https://YOUR-API.onrender.com/api/oauth/schwab/callback
# SCHWAB_MARKET_CALLBACK_URL=https://YOUR-API.onrender.com/api/oauth/schwab/market/callback

# --- Render injects these from the Blueprint (do not set manually if using render.yaml) ---
# REDIS_URL=
# DATABASE_URL=   # use Render Postgres internal URL instead of Supabase if you use Render DB
