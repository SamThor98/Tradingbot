{
  "name": "scanner-parameter-ablation-v1",
  "schema_version": "1.0",
  "as_of": "2026-05-14",
  "objective": {
    "primary_metric": "expectancy_per_trade",
    "guardrails": [
      "max_drawdown",
      "trade_count",
      "hit_rate"
    ],
    "promotion_rules": {
      "primary_min_relative_lift": 0.05,
      "max_drawdown_max_relative_worsening": 0.1,
      "min_trade_count_ratio_vs_baseline": 0.8
    }
  },
  "data_splits": {
    "train_windows": [
      [
        "2023-01-01",
        "2023-12-31"
      ],
      [
        "2024-01-01",
        "2024-12-31"
      ]
    ],
    "test_windows": [
      [
        "2025-01-01",
        "2025-06-30"
      ],
      [
        "2025-07-01",
        "2025-12-31"
      ]
    ],
    "regime_slices": [
      "bull",
      "chop",
      "bear"
    ]
  },
  "execution": {
    "baseline_command": "{python} scripts/validate_all.py --profile ci --skip-backtest --strict",
    "per_variant_backtest_command": "{python} scripts/validate_backtest.py --tickers 20 --start {start_date}",
    "metrics_file": ".backtest_results.json",
    "min_trades_per_variant": 50,
    "bootstrap_samples": 1000,
    "confidence_level": 0.95
  },
  "experiments": [
    {
      "id": "E01_stage2_52w_pct",
      "param": "STAGE2_52W_PCT",
      "type": "single_param",
      "values": [
        0.7,
        0.75,
        0.8
      ],
      "baseline": 0.75
    },
    {
      "id": "E02_vcp_days",
      "param": "VCP_DAYS",
      "type": "single_param",
      "values": [
        3,
        4,
        5
      ],
      "baseline": 4
    },
    {
      "id": "E03_quality_min_signal_score",
      "param": "QUALITY_MIN_SIGNAL_SCORE",
      "type": "single_param",
      "values": [
        45,
        50,
        55
      ],
      "baseline": 50
    },
    {
      "id": "E04_regime_v2_entry_min_score",
      "param": "REGIME_V2_ENTRY_MIN_SCORE",
      "type": "single_param",
      "values": [
        50,
        55,
        60
      ],
      "baseline": 55
    },
    {
      "id": "E05_breakout_volume_min_ratio",
      "param": "QUALITY_BREAKOUT_VOLUME_MIN_RATIO",
      "type": "single_param",
      "values": [
        0.85,
        0.9,
        1.0
      ],
      "baseline": 0.9
    },
    {
      "id": "E06_pead_boost",
      "param": "PEAD_SCORE_BOOST",
      "type": "single_param",
      "values": [
        2.0,
        3.0,
        4.0
      ],
      "baseline": 3.0
    },
    {
      "id": "E07_pead_penalty",
      "param": "PEAD_SCORE_PENALTY",
      "type": "single_param",
      "values": [
        2.0,
        3.0,
        4.0
      ],
      "baseline": 3.0
    }
  ],
  "interaction_followups": [
    {
      "id": "I01_quality_x_vcp",
      "params": [
        "QUALITY_MIN_SIGNAL_SCORE",
        "VCP_DAYS"
      ],
      "grid": {
        "QUALITY_MIN_SIGNAL_SCORE": [
          45,
          50,
          55
        ],
        "VCP_DAYS": [
          3,
          4,
          5
        ]
      }
    },
    {
      "id": "I02_stage2_x_quality",
      "params": [
        "STAGE2_52W_PCT",
        "QUALITY_MIN_SIGNAL_SCORE"
      ],
      "grid": {
        "STAGE2_52W_PCT": [
          0.7,
          0.75,
          0.8
        ],
        "QUALITY_MIN_SIGNAL_SCORE": [
          45,
          50,
          55
        ]
      }
    }
  ],
  "conviction_validation": {
    "required_tests": [
      "cohort_monotonicity_by_mirofish_conviction",
      "incremental_lift_with_vs_without_conviction_contribution",
      "self_study_filter_counterfactual",
      "regime_stability_of_conviction_lift"
    ],
    "pass_criteria": {
      "monotonicity_min_pass_rate": 0.66,
      "aggregate_lift_must_be_positive": true,
      "regime_slice_positive_lift_min_count": 2
    },
    "reference_scripts": [
      "scripts/analyze_cohorts.py",
      "scripts/score_hypothesis_outcomes.py",
      "scripts/score_counterfactual_outcomes.py"
    ]
  },
  "reporting": {
    "output_file": "validation_artifacts/ablation_report_v1.json",
    "leaderboard_top_n": 10,
    "fields": [
      "experiment_id",
      "variant",
      "expectancy_per_trade",
      "max_drawdown",
      "hit_rate",
      "trade_count",
      "relative_lift_vs_baseline",
      "ci_lower",
      "ci_upper",
      "regression_flags"
    ]
  }
}
