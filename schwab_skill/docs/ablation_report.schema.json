{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tradingbot.local/schemas/ablation_report.schema.json",
  "title": "AblationReport",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "raw_artifact",
    "objective",
    "summary",
    "leaderboard"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "raw_artifact": {
      "type": "string"
    },
    "objective": {
      "type": "object",
      "required": [
        "primary_metric",
        "guardrails",
        "promotion_rules",
        "bootstrap_samples",
        "confidence_level"
      ],
      "properties": {
        "primary_metric": {
          "type": "string"
        },
        "guardrails": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "promotion_rules": {
          "type": "object"
        },
        "bootstrap_samples": {
          "type": "integer"
        },
        "confidence_level": {
          "type": "number"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "variant_count",
        "pass_count",
        "fail_count",
        "best_variant"
      ],
      "properties": {
        "variant_count": {
          "type": "integer"
        },
        "pass_count": {
          "type": "integer"
        },
        "fail_count": {
          "type": "integer"
        },
        "best_variant": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "leaderboard": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "variant_id",
          "experiment_id",
          "variant_type",
          "description",
          "env_overrides",
          "primary_metric_key",
          "relative_lift_vs_baseline",
          "ci_relative_lift_lower",
          "ci_relative_lift_upper",
          "paired_primary_count",
          "guardrails",
          "regression_flags",
          "pass"
        ],
        "properties": {
          "variant_id": {
            "type": "string"
          },
          "experiment_id": {
            "type": "string"
          },
          "variant_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "env_overrides": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "primary_metric_key": {
            "type": "string"
          },
          "primary_baseline_mean": {
            "type": [
              "number",
              "null"
            ]
          },
          "primary_variant_mean": {
            "type": [
              "number",
              "null"
            ]
          },
          "relative_lift_vs_baseline": {
            "type": [
              "number",
              "null"
            ]
          },
          "ci_relative_lift_lower": {
            "type": [
              "number",
              "null"
            ]
          },
          "ci_relative_lift_upper": {
            "type": [
              "number",
              "null"
            ]
          },
          "paired_primary_count": {
            "type": "integer"
          },
          "guardrails": {
            "type": "object"
          },
          "regression_flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "pass": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
