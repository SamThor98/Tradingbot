# Core runtime
DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/tradingbot
REDIS_URL=redis://localhost:6379/0

# Security/auth
CREDENTIAL_ENCRYPTION_KEY=replace_with_urlsafe_base64_32byte_key
SUPABASE_JWT_SECRET=replace_with_supabase_jwt_secret
SUPABASE_JWT_SECRET_LEGACY=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
WEB_ALLOWED_ORIGINS=https://your-frontend.example.com
WEB_INTERNAL_API_KEY=replace_with_internal_metrics_key

# Billing
SAAS_BILLING_ENFORCE=0
SAAS_ENABLE_STRIPE_WEBHOOK=1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=

# Schwab dual-app OAuth
SCHWAB_MARKET_APP_KEY=
SCHWAB_MARKET_APP_SECRET=
SCHWAB_ACCOUNT_APP_KEY=
SCHWAB_ACCOUNT_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182/
SCHWAB_MARKET_CALLBACK_URL=https://127.0.0.1:8182/

# Deployment/migrations
SAAS_HEALTH_REQUIRE_REDIS=1
SAAS_HEALTH_REQUIRE_WORKERS=1
SAAS_RUN_ALEMBIC=1
SAAS_BOOTSTRAP_SCHEMA=0
SAAS_DISABLE_PLATFORM_MARKET_FALLBACK=0
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
CELERY_WORKER_POOL=solo
CELERY_WORKER_CONCURRENCY=

# Exit returns promotion (2026-Q2): defer early exits; edge lives in 21-40d holds
BACKTEST_HOLD_DAYS=40
BACKTEST_MIN_HOLD_DAYS_BEFORE_TRAIL=15
BACKTEST_MIN_HOLD_DEFER_SOFT_EXITS=true
HOLD_DAYS=40
EXIT_MAX_HOLD_DAYS=40
EXIT_MIN_HOLD_DAYS_BEFORE_TRAIL=15
# Promoted after exit-grace shadow run and explicit operator approval
EXIT_MANAGER_MODE=live

# Signal scoring — composite quality rank v3 (direct volume/signal/miro + safety caps)
SCORE_EDGE_EXCLUDE_52W=true
SCORE_EDGE_SIGNAL_WEIGHT=0.85
SCORE_EDGE_PUP_WEIGHT=0.15
SCORE_EDGE_SIGNAL_WEIGHT=1.0
SCORE_EDGE_PUP_WEIGHT=0.0
SCORE_COMPOSITE_USE_DIRECT_COMPONENTS=true
SCORE_COMPOSITE_DIRECT_TREND_WEIGHT=0.70
SCORE_COMPOSITE_DIRECT_VOLUME_WEIGHT=0.20
SCORE_COMPOSITE_DIRECT_SIGNAL_WEIGHT=0.05
SCORE_COMPOSITE_DIRECT_MIROFISH_WEIGHT=0.05
SCORE_COMPOSITE_STACK_BLEND_WEIGHT=0.0
SCORE_COMPOSITE_SAFETY_CAPS_ONLY=true
SCORE_COMPOSITE_EDGE_WEIGHT=0.0
SCORE_COMPOSITE_RELIABILITY_WEIGHT=0.0
SCORE_COMPOSITE_EXECUTION_WEIGHT=0.0
SCORE_PTS_SMA_CAP=25
SCORE_PTS_SMA_MULTIPLIER=0.0
RANK_SCORE_V2_MODE=shadow
RANK_V2_SIGNAL_WEIGHT=0.35
RANK_V2_VOLUME_WEIGHT=0.50
RANK_V2_MIROFISH_WEIGHT=0.15
RANK_V2_EXCLUDE_52W=true
# Live candidate sort: signal_score until a challenger clears realized-trade validation.
# rank_score_v2 is supported for shadow/backtest parity but is not the default.
SCAN_LIVE_SORT_KEY=signal_score

# Entry intelligence: shadow-only until counterfactual evidence clears promotion
META_POLICY_MODE=shadow
UNCERTAINTY_MODE=shadow
CONFLUENCE_GATE_MODE=shadow
QUALITY_GATES_MODE=shadow
# P0 signal-edge shadow counters (never block; see SIGNAL_QUALITY_ROLLOUT.md Stage 2)
SIGNAL_EDGE_SHADOW_MODE=shadow
RANK_FILTER_SHADOW_MIN_PERCENTILE_COMPOSITE=50
RANK_FILTER_SHADOW_MIN_PERCENTILE_RANK_V2=75
RANK_FILTER_V2_MODE=live
RANK_FILTER_SHADOW_MIN_PERCENTILE_SIGNAL=70
STAGE2_SHADOW_52W_PCT=0.88
STAGE2_SHADOW_SMA_UPWARD_DAYS=25
# P0 entry-timing LIVE (breakout-buffer-only 1%; SMA50 caps off — offline validated)
ENTRY_TIMING_SHADOW_MODE=live
ENTRY_SHADOW_MIN_PCT_ABOVE_SMA50=0.01
ENTRY_SHADOW_MAX_PCT_ABOVE_SMA50=0.25
ENTRY_SHADOW_MIN_BREAKOUT_BUFFER_PCT=0.01
ENTRY_SHADOW_DISABLE_SMA50_FILTERS=true
# Operating stack: live buffer + live exit grace (15/40). Apply with:
#   python scripts/apply_signal_stack_enforced_env.py
#   python scripts/start_local_dashboard.py --signal-stack-enforced
# Clean counterfactual week (demotes entry to shadow + turns off event/exec plugins):
#   python scripts/apply_signal_stack_shadow_env.py
# After scan: python scripts/compare_live_entry_shadow_to_offline.py --write-artifact
# Preflight: python scripts/validate_signal_stack_enforced_env.py
COUNTERFACTUAL_LOGGING_ENABLED=true
# Book YTD Excel export (Portfolio → Book). Canonical file under exports/; EOD via bot loop.
# BOOK_YTD_EXPORT_ENABLED=true
# BOOK_YTD_EXPORT_HHMM=16:30
# BOOK_YTD_EXPORT_PATH=exports/book_ytd_{year}.xlsx
